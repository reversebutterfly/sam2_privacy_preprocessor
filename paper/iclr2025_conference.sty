% Minimal ICLR 2025 compatible style
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{iclr2025_conference}[2025/01/01 ICLR 2025 style]

\usepackage{amsmath,amsfonts,amssymb}
\usepackage{geometry}
\geometry{
  letterpaper,
  top=1in, bottom=1in,
  left=1.25in, right=1.25in,
  headheight=14pt
}
\usepackage{times}
\usepackage{microtype}
\usepackage{booktabs}
\usepackage{url}
\usepackage{hyperref}
\hypersetup{
  colorlinks=true,
  linkcolor=blue,
  citecolor=blue,
  urlcolor=blue,
}
\usepackage{natbib}

% Section formatting
\usepackage{titlesec}
\titlespacing*{\section}{0pt}{12pt plus 2pt minus 2pt}{6pt plus 1pt minus 1pt}
\titlespacing*{\subsection}{0pt}{8pt plus 1pt minus 1pt}{4pt plus 1pt minus 1pt}

% Caption formatting
\usepackage{caption}
\captionsetup{font=small, labelfont=bf, skip=4pt}

% Paragraph spacing
\setlength{\parskip}{0pt}
\setlength{\parindent}{12pt}

% Abstract
\renewenvironment{abstract}{%
  \centerline{\textbf{Abstract}}%
  \vspace{4pt}%
  \begin{quote}\small
}{%
  \end{quote}%
  \vspace{8pt}%
}
